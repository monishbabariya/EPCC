# EPCC — local dev environment template.
# Copy to .env.local and adjust as needed. Values below are safe defaults
# for `make up` to bring the stack online; do NOT use these in production.

# ===== Backend =====
EPCC_ENV=dev
EPCC_API_HOST=0.0.0.0
EPCC_API_PORT=8000
EPCC_API_LOG_LEVEL=info
EPCC_API_CORS_ORIGINS=http://localhost:5173

# ===== Database =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=epcc
POSTGRES_PASSWORD=epcc_dev_password
POSTGRES_DB=epcc
DATABASE_URL=postgresql+asyncpg://epcc:epcc_dev_password@localhost:5432/epcc

# ===== Redis (Celery broker + result backend) =====
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ===== MinIO (S3-compatible object storage) =====
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=miniopassword
MINIO_BUCKET_PHOTOS=epcc-photos
MINIO_BUCKET_DOCUMENTS=epcc-documents
MINIO_BUCKET_EXPORTS=epcc-exports

# ===== Keycloak (OIDC) =====
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=epcc
KEYCLOAK_CLIENT_ID=epcc-api
KEYCLOAK_CLIENT_SECRET=dev-client-secret-change-me

# ===== Frontend =====
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=epcc
VITE_KEYCLOAK_CLIENT_ID=epcc-web
